{
  "name": "tauri-plugin-rekognition-liveness-api",
  "version": "0.1.0",
  "description": "AWS Rekognition Face Liveness for Tauri 2 — native Android/iOS UI bindings.",
  "type": "module",
  "types": "./dist-js/index.d.ts",
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "license": "MIT",
  "exports": {
    "types": "./dist-js/index.d.ts",
    "import": "./dist-js/index.js",
    "require": "./dist-js/index.cjs"
  },
  "bin": {
    "tauri-plugin-rekognition-liveness": "./scripts/setup.mjs"
  },
  "files": [
    "dist-js",
    "scripts/setup.mjs",
    "scripts/bootstrap-ios-caches.sh",
    "README.md"
  ],
  "keywords": [
    "tauri",
    "plugin",
    "aws",
    "rekognition",
    "rekognition-liveness",
    "android",
    "ios",
    "amplify"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "pnpm build",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": ">=2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
