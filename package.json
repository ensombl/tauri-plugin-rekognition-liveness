{
  "name": "tauri-plugin-rekognition-liveness-api",
  "version": "0.1.0",
  "description": "AWS Rekognition Face Liveness for Tauri 2 — native Android/iOS UI bindings.",
  "license": "MIT",
  "author": "SoSweetHam <sosweetham@gmail.com>",
  "contributors": [
    "Ensombl Team <team@ensombl.io>"
  ],
  "homepage": "https://github.com/sosweetham/tauri-plugin-rekognition-liveness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sosweetham/tauri-plugin-rekognition-liveness.git"
  },
  "bugs": {
    "url": "https://github.com/sosweetham/tauri-plugin-rekognition-liveness/issues"
  },
  "type": "module",
  "types": "./dist-js/index.d.ts",
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "exports": {
    "types": "./dist-js/index.d.ts",
    "import": "./dist-js/index.js",
    "require": "./dist-js/index.cjs"
  },
  "bin": {
    "tauri-plugin-rekognition-liveness": "./scripts/setup.mjs"
  },
  "files": [
    "dist-js",
    "scripts/setup.mjs",
    "scripts/bootstrap-ios-caches.sh",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tauri",
    "tauri-plugin",
    "aws",
    "rekognition",
    "rekognition-liveness",
    "face-liveness",
    "kyc",
    "biometric",
    "android",
    "ios",
    "amplify"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "pnpm build",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": ">=2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
