{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-plugin-rekognition-liveness-demo",
  "version": "0.1.0",
  "identifier": "app.tauri.rekognitionlivenessdemo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Face Liveness Demo",
        "width": 480
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "15.0",
      "developmentTeam": "FSAH2JB8F4"
    }
  }
}
