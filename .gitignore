dist-js
node_modules
target
Cargo.lock

# Tauri-generated mobile API stubs (re-fetched on `tauri ios init` / `tauri android init`)
.tauri/
android/.tauri/
ios/.build/

# Android (plugin module) build outputs — regenerated on every gradle build.
android/build/
android/.gradle/
android/local.properties

# iOS / SwiftPM
# - .swiftpm/: per-machine Xcode + SwiftPM workspace state (window positions,
#   build database, schemes management). Never source-controlled.
# - Package.resolved: SwiftPM lockfile. For *library* packages (which this is)
#   the convention is to ignore it — pinning transitive versions for consumers
#   is up to *their* root Package.resolved. If you ever turn this into an app,
#   commit Package.resolved instead.
ios/.swiftpm/
ios/Package.resolved

# Tauri auto-generates these from build.rs but they're committed-by-convention.
# Comment out the next line if you want to track schema changes in version control.
# permissions/autogenerated/

# Tauri-generated artefacts in the example app
examples/*/dist
examples/*/src-tauri/target
examples/*/src-tauri/gen
examples/*/build
examples/*/.svelte-kit
